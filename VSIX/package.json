{
	"name": "snow-cli",
	"displayName": "%extension.displayName%",
	"description": "%extension.description%",
	"version": "0.4.25",
	"publisher": "mufasa",
	"icon": "snow.png",
	"repository": {
		"type": "git",
		"url": "https://github.com/MayDay-wpf/snow-cli"
	},
	"engines": {
		"vscode": "^1.106.0"
	},
	"categories": [
		"Other"
	],
	"main": "./dist/extension.js",
	"activationEvents": [
		"onStartupFinished"
	],
	"contributes": {
		"configuration": [
			{
				"id": "snow-cli.general",
				"order": 1,
				"title": "%config.category.general%",
				"properties": {
					"snow-cli.terminalMode": {
						"order": 1,
						"type": "string",
						"default": "sidebar",
						"enum": [
							"sidebar",
							"split"
						],
						"enumDescriptions": [
							"%config.terminalMode.enum.sidebar%",
							"%config.terminalMode.enum.split%"
						],
						"description": "%config.terminalMode.description%"
					},
					"snow-cli.startupCommand": {
						"order": 2,
						"type": "string",
						"default": "snow",
						"description": "%config.startupCommand.description%"
					}
				}
			},
			{
				"id": "snow-cli.terminal",
				"order": 2,
				"title": "%config.category.terminal%",
				"properties": {
					"snow-cli.terminal.shellType": {
						"order": 1,
						"type": "string",
						"default": "auto",
						"description": "%config.terminal.shellType.description%"
					},
					"snow-cli.terminal.proxyUrl": {
						"order": 2,
						"type": "string",
						"default": "",
						"description": "%config.terminal.proxyUrl.description%"
					},
					"snow-cli.terminal.fontFamily": {
						"order": 3,
						"type": "string",
						"default": "",
						"description": "%config.terminal.fontFamily.description%"
					},
					"snow-cli.terminal.fontSize": {
						"order": 4,
						"type": "number",
						"default": 14,
						"minimum": 8,
						"maximum": 32,
						"description": "%config.terminal.fontSize.description%"
					},
					"snow-cli.terminal.fontWeight": {
						"order": 5,
						"type": "string",
						"default": "normal",
						"enum": [
							"normal",
							"bold",
							"100",
							"200",
							"300",
							"400",
							"500",
							"600",
							"700",
							"800",
							"900"
						],
						"description": "%config.terminal.fontWeight.description%"
					},
					"snow-cli.terminal.lineHeight": {
						"order": 6,
						"type": "number",
						"default": 1,
						"minimum": 0.8,
						"maximum": 2,
						"description": "%config.terminal.lineHeight.description%"
					}
				}
			},
			{
				"id": "snow-cli.bell",
				"order": 3,
				"title": "%config.category.bell%",
				"properties": {
					"snow-cli.bell.enabled": {
						"order": 1,
						"type": "boolean",
						"default": true,
						"description": "%config.bell.enabled.description%"
					},
					"snow-cli.bell.sound": {
						"order": 2,
						"type": "string",
						"default": "beep",
						"enum": [
							"beep",
							"ding",
							"chime",
							"pluck",
							"blip",
							"none"
						],
						"enumDescriptions": [
							"%config.bell.sound.enum.beep%",
							"%config.bell.sound.enum.ding%",
							"%config.bell.sound.enum.chime%",
							"%config.bell.sound.enum.pluck%",
							"%config.bell.sound.enum.blip%",
							"%config.bell.sound.enum.none%"
						],
						"description": "%config.bell.sound.description%"
					},
					"snow-cli.bell.volume": {
						"order": 3,
						"type": "number",
						"default": 0.5,
						"minimum": 0,
						"maximum": 1,
						"description": "%config.bell.volume.description%"
					},
					"snow-cli.bell.visualFlash": {
						"order": 4,
						"type": "boolean",
						"default": true,
						"description": "%config.bell.visualFlash.description%"
					}
				}
			},
			{
				"id": "snow-cli.gitBlame",
				"order": 4,
				"title": "%config.category.gitBlame%",
				"properties": {
					"snow-cli.gitBlame.enabled": {
						"order": 1,
						"type": "boolean",
						"default": false,
						"description": "%config.gitBlame.enabled.description%"
					}
				}
			},
			{
				"id": "snow-cli.completion",
				"order": 5,
				"title": "%config.category.completion%",
				"properties": {
					"snow-cli.completion.enabled": {
						"order": 1,
						"type": "boolean",
						"default": false,
						"description": "%config.completion.enabled.description%"
					},
					"snow-cli.completion.provider": {
						"order": 2,
						"type": "string",
						"default": "chat",
						"enum": [
							"chat",
							"fim",
							"responses",
							"gemini",
							"anthropic"
						],
						"enumDescriptions": [
							"%config.completion.provider.enum.chat%",
							"%config.completion.provider.enum.fim%",
							"%config.completion.provider.enum.responses%",
							"%config.completion.provider.enum.gemini%",
							"%config.completion.provider.enum.anthropic%"
						],
						"description": "%config.completion.provider.description%"
					},
					"snow-cli.completion.baseUrl": {
						"order": 3,
						"type": "string",
						"default": "",
						"description": "%config.completion.baseUrl.description%"
					},
					"snow-cli.completion.apiKey": {
						"order": 4,
						"type": "string",
						"default": "",
						"description": "%config.completion.apiKey.description%"
					},
					"snow-cli.completion.model": {
						"order": 5,
						"type": "string",
						"default": "",
						"description": "%config.completion.model.description%"
					},
					"snow-cli.completion.maxTokens": {
						"order": 6,
						"type": "number",
						"default": 256,
						"minimum": 16,
						"maximum": 4096,
						"description": "%config.completion.maxTokens.description%"
					},
					"snow-cli.completion.temperature": {
						"order": 7,
						"type": "number",
						"default": 0.2,
						"minimum": 0,
						"maximum": 2,
						"description": "%config.completion.temperature.description%"
					},
					"snow-cli.completion.debounceMs": {
						"order": 8,
						"type": "number",
						"default": 400,
						"minimum": 50,
						"maximum": 5000,
						"description": "%config.completion.debounceMs.description%"
					},
					"snow-cli.completion.contextPrefixLines": {
						"order": 9,
						"type": "number",
						"default": 120,
						"minimum": 10,
						"maximum": 1000,
						"description": "%config.completion.contextPrefixLines.description%"
					},
					"snow-cli.completion.contextSuffixLines": {
						"order": 10,
						"type": "number",
						"default": 40,
						"minimum": 0,
						"maximum": 500,
						"description": "%config.completion.contextSuffixLines.description%"
					},
					"snow-cli.completion.languages": {
						"order": 11,
						"type": "array",
						"items": {
							"type": "string"
						},
						"default": [
							"*"
						],
						"description": "%config.completion.languages.description%"
					},
					"snow-cli.completion.proxy": {
						"order": 12,
						"type": "string",
						"default": "",
						"description": "%config.completion.proxy.description%"
					}
				}
			},
			{
				"id": "snow-cli.nextEdit",
				"order": 6,
				"title": "%config.category.nextEdit%",
				"properties": {
					"snow-cli.nextEdit.enabled": {
						"order": 1,
						"type": "boolean",
						"default": false,
						"description": "%config.nextEdit.enabled.description%"
					},
					"snow-cli.nextEdit.scope": {
						"order": 2,
						"type": "string",
						"default": "file",
						"enum": [
							"file",
							"workspace"
						],
						"enumDescriptions": [
							"%config.nextEdit.scope.enum.file%",
							"%config.nextEdit.scope.enum.workspace%"
						],
						"description": "%config.nextEdit.scope.description%"
					},
					"snow-cli.nextEdit.useLspReferences": {
						"order": 3,
						"type": "boolean",
						"default": true,
						"description": "%config.nextEdit.useLspReferences.description%"
					},
					"snow-cli.nextEdit.maxCandidates": {
						"order": 4,
						"type": "number",
						"default": 20,
						"minimum": 1,
						"maximum": 200,
						"description": "%config.nextEdit.maxCandidates.description%"
					},
					"snow-cli.nextEdit.minPatternLength": {
						"order": 5,
						"type": "number",
						"default": 2,
						"minimum": 1,
						"maximum": 20,
						"description": "%config.nextEdit.minPatternLength.description%"
					},
					"snow-cli.nextEdit.debounceMs": {
						"order": 6,
						"type": "number",
						"default": 350,
						"minimum": 50,
						"maximum": 5000,
						"description": "%config.nextEdit.debounceMs.description%"
					}
				}
			}
		],
		"viewsContainers": {
			"secondarySidebar": [
				{
					"id": "snow-cli-sidebar",
					"title": "%viewsContainer.sidebar.title%",
					"icon": "snow.png"
				}
			]
		},
		"views": {
			"snow-cli-sidebar": [
				{
					"type": "webview",
					"id": "snowCliTerminal",
					"name": "%view.terminal.name%",
					"icon": "snow.png",
					"when": "snow-cli.sidebarMode"
				}
			]
		},
		"commands": [
			{
				"command": "snow-cli.openTerminal",
				"title": "%command.openTerminal.title%",
				"icon": {
					"light": "./snow.png",
					"dark": "./snow.png"
				}
			},
			{
				"command": "snow-cli.restartSidebarTerminal",
				"title": "%command.restartSidebarTerminal.title%",
				"icon": "$(debug-rerun)"
			},
			{
				"command": "snow-cli.newSidebarTerminalTab",
				"title": "%command.newSidebarTerminalTab.title%",
				"icon": "$(add)"
			},
			{
				"command": "snow-cli.openSnowSettings",
				"title": "%command.openSnowSettings.title%",
				"icon": "$(settings-gear)"
			},
			{
				"command": "snow-cli.focusSidebar",
				"title": "%command.focusSidebar.title%"
			},
			{
				"command": "snow-cli.addFolderPath",
				"title": "%command.addFolderPath.title%",
				"icon": "$(file-symlink-directory)"
			},
			{
				"command": "snow-cli.addFilePath",
				"title": "%command.addFilePath.title%",
				"icon": "$(file-symlink-file)"
			},
			{
				"command": "snow-cli.sendFilePaths",
				"title": "%command.sendFilePaths.title%",
				"icon": "$(file-symlink-file)"
			},
			{
				"command": "snow-cli.sendSelectionLocation",
				"title": "%command.sendSelectionLocation.title%",
				"icon": "$(file-symlink-file)"
			},
			{
				"command": "snow-cli.toggleGitBlame",
				"title": "%command.toggleGitBlame.title%",
				"icon": "$(git-commit)"
			},
			{
				"command": "snow-cli.toggleFileAnnotations",
				"title": "%command.toggleFileAnnotations.title%",
				"icon": "$(list-flat)"
			},
			{
				"command": "snow-cli.generateCommitMessage",
				"title": "%command.generateCommitMessage.title%",
				"icon": {
					"light": "./snow.png",
					"dark": "./snow.png"
				}
			},
			{
				"command": "snow-cli.generateCommitMessageWithRequirements",
				"title": "%command.generateCommitMessageWithRequirements.title%",
				"icon": "$(comment)"
			},
			{
				"command": "snow-cli.cancelCommitMessageGeneration",
				"title": "%command.cancelCommitMessageGeneration.title%",
				"icon": "$(debug-stop)"
			},
			{
				"command": "snow-cli.completion.toggle",
				"title": "%command.completion.toggle.title%"
			},
			{
				"command": "snow-cli.completion.selectModel",
				"title": "%command.completion.selectModel.title%"
			},
			{
				"command": "snow-cli.completion.trigger",
				"title": "%command.completion.trigger.title%"
			},
			{
				"command": "snow-cli.nextEdit.toggle",
				"title": "%command.nextEdit.toggle.title%"
			},
			{
				"command": "snow-cli.nextEdit.trigger",
				"title": "%command.nextEdit.trigger.title%"
			},
			{
				"command": "snow-cli.nextEdit.accept",
				"title": "%command.nextEdit.accept.title%"
			},
			{
				"command": "snow-cli.nextEdit.next",
				"title": "%command.nextEdit.next.title%"
			},
			{
				"command": "snow-cli.nextEdit.dismiss",
				"title": "%command.nextEdit.dismiss.title%"
			},
			{
				"command": "snow-cli.nextEdit.showLogs",
				"title": "%command.nextEdit.showLogs.title%"
			}
		],
		"submenus": [
			{
				"id": "snow-cli.insertPathActions",
				"label": "%submenu.insertPathActions.label%",
				"icon": "$(attach)"
			}
		],
		"keybindings": [
			{
				"command": "snow-cli.focusSidebar",
				"key": "ctrl+alt+s",
				"mac": "cmd+alt+s"
			},
			{
				"command": "snow-cli.nextEdit.accept",
				"key": "tab",
				"when": "snow-cli.nextEditActive && editorTextFocus && !editorReadonly && !suggestWidgetVisible && !inlineSuggestionVisible && !inSnippetMode"
			},
			{
				"command": "snow-cli.nextEdit.next",
				"key": "alt+]",
				"mac": "alt+]",
				"when": "snow-cli.nextEditActive"
			},
			{
				"command": "snow-cli.nextEdit.dismiss",
				"key": "escape",
				"when": "snow-cli.nextEditActive && editorTextFocus && !suggestWidgetVisible && !inlineSuggestionVisible"
			}
		],
		"menus": {
			"view/title": [
				{
					"command": "snow-cli.restartSidebarTerminal",
					"when": "view == snowCliTerminal && snow-cli.sidebarMode",
					"group": "navigation@1"
				},
				{
					"command": "snow-cli.newSidebarTerminalTab",
					"when": "view == snowCliTerminal && snow-cli.sidebarMode",
					"group": "navigation@2"
				},
				{
					"command": "snow-cli.openSnowSettings",
					"when": "view == snowCliTerminal && snow-cli.sidebarMode",
					"group": "navigation@3"
				},
				{
					"submenu": "snow-cli.insertPathActions",
					"when": "view == snowCliTerminal && snow-cli.sidebarMode",
					"group": "navigation@4"
				}
			],
			"snow-cli.insertPathActions": [
				{
					"command": "snow-cli.addFolderPath",
					"group": "navigation@1"
				},
				{
					"command": "snow-cli.addFilePath",
					"group": "navigation@2"
				}
			],
			"editor/title": [
				{
					"command": "snow-cli.openTerminal",
					"group": "navigation"
				}
			],
			"editor/title/context": [
				{
					"command": "snow-cli.sendFilePaths",
					"when": "resourceScheme == file || resourceScheme == vscode-remote",
					"group": "snow@1"
				}
			],
			"editor/context": [
				{
					"command": "snow-cli.sendSelectionLocation",
					"when": "editorHasSelection && (resourceScheme == file || resourceScheme == vscode-remote)",
					"group": "snow@1"
				}
			],
			"explorer/context": [
				{
					"command": "snow-cli.sendFilePaths",
					"group": "snow@1"
				}
			],
			"scm/title": [
				{
					"command": "snow-cli.generateCommitMessage",
					"alt": "snow-cli.generateCommitMessageWithRequirements",
					"when": "!snow-cli.commitMessageGenerating",
					"group": "navigation@1"
				},
				{
					"command": "snow-cli.generateCommitMessageWithRequirements",
					"when": "!snow-cli.commitMessageGenerating",
					"group": "snow@1"
				},
				{
					"command": "snow-cli.cancelCommitMessageGeneration",
					"when": "snow-cli.commitMessageGenerating",
					"group": "navigation@1"
				}
			]
		}
	},
	"scripts": {
		"compile": "webpack",
		"watch": "webpack --watch",
		"package": "webpack --mode production --devtool hidden-source-map",
		"rebuild": "npm rebuild node-pty",
		"lint": "eslint src --ext ts",
		"pretest": "npm run compile && npm run lint",
		"test": "node ./out/test/runTest.js",
		"vscode:prepublish": "npm run package"
	},
	"dependencies": {
		"@anthropic-ai/sdk": "^0.95.2",
		"@google/genai": "^2.0.1",
		"@xterm/addon-fit": "^0.11.0",
		"@xterm/addon-search": "^0.16.0",
		"@xterm/addon-unicode11": "^0.9.0",
		"@xterm/addon-web-links": "^0.12.0",
		"@xterm/addon-webgl": "^0.19.0",
		"@xterm/xterm": "^6.0.0",
		"node-pty": "1.2.0-beta.10",
		"openai": "^6.37.0",
		"ws": "^8.14.2"
	},
	"devDependencies": {
		"@types/node": "20.x",
		"@types/vscode": "^1.75.0",
		"@types/ws": "^8.5.8",
		"@vscode/vsce": "^2.22.0",
		"ts-loader": "^9.5.0",
		"typescript": "^5.3.0",
		"webpack": "^5.90.0",
		"webpack-cli": "^5.1.0"
	}
}
